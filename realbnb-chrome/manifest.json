{
	"manifest_version": 3,
	"name": "RealBnB",
	"version": "1.0",
	"description": "Analyze Airbnb listings to determine if they are likely primary residences or dedicated rental properties",
	"icons": {
	  "48": "icons/realbnb-icon.png"
	},

	"permissions": [
	  "activeTab",
	  "scripting",
	  "tabs",
	  "webNavigation",
	  "storage"
	],
	"host_permissions": [
	  "*://www.airbnb.com/rooms/*",
	  "https://api.openai.com/v1/chat/completions"
	],

	"action": {
	  "default_icon": "icons/realbnb-icon.png",
	  "default_title": "RealBnB",
	  "default_popup": "popup/realbnb.html"
	},

	"background": {
	  "service_worker": "background.js",
	  "type": "module"
	},

	"options_ui": {
	  "page": "options/options.html",
	  "open_in_tab": true
	},

	"web_accessible_resources": [{
	  "resources": ["browser-polyfill.js"],
	  "matches": ["<all_urls>"]
	}]
  }
